      "texto": "[Coro] ritmo normal, corte en \"soy\""
    },
    {
      "tipo": "acorde",
      "texto": "Dm                     Gm   C"
    },
    {
      "tipo": "letra",
      "texto": "Soy intocable bajo tus alas "
    },
    {
      "tipo": "acorde",
      "texto": "                             F"
    },
    {
      "tipo": "letra",
      "texto": "Soy invencible si tú vas conmigo"
