    {
      "tipo": "acorde",
      "texto": "          Dm"
    },
    {
      "tipo": "letra",
      "texto": "Eres mi protector"
    },
    {
      "tipo": "letra",
      "texto": "Cada lágrima que cae "
    },
    {
      "tipo": "acorde",
      "texto": "      Gm"
    },
    {
      "tipo": "letra",
      "texto": "Tú la vienes a sanar"
    },
    {
      "tipo": "acorde",
      "texto": "        Bb"
    },
    {
      "tipo": "letra",
      "texto": "Y en el medio de la guerra"
    },
    {
      "tipo": "acorde",
      "texto": "       A               A7"
    },
    {
      "tipo": "letra",
      "texto": "Sé que tú vas a pelear."
    },
    {
      "tipo": "letra",
      "texto": ""
    },
    {
      "tipo": "tag",
      "texto": "[Precoro]  caja en 4to--creciendo"
    },
    {
      "tipo": "acorde",
      "texto": "                  Gm"
    },
    {
      "tipo": "letra",
      "texto": "Tú vas delante de mí"
    },
    {
      "tipo": "letra",
      "texto": "Abriendo el camino"
    },
    {
      "tipo": "acorde",
      "texto": "                 C"
    },
    {
      "tipo": "letra",
      "texto": "Con fuego en tus ojos"
    },
    {
      "tipo": "letra",
      "texto": "El cielo está conmigo"
    },
    {
      "tipo": "acorde",
      "texto": "                  F"
    },
    {
      "tipo": "letra",
      "texto": "No hay poder del mal"
    },
    {
      "tipo": "letra",
      "texto": "Que pueda detener"
    },
    {
      "tipo": "acorde",
      "texto": "               A"
    },
    {
      "tipo": "letra",
      "texto": "Al Dios invencible"
    },
    {
      "tipo": "letra",
      "texto": "que lucha por mi ser"
    },
    {
      "tipo": "letra",
      "texto": ""
    },
    {
