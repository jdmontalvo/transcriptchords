    {
      "tipo": "acorde",
      "texto": "          Dm"
    },
    {
      "tipo": "letra",
      "texto": "Mi debilidad"
    },
    {
      "tipo": "letra",
      "texto": "Yo me aferro a tus promesas"
    },
    {
      "tipo": "acorde",
      "texto": "      Gm"
    },
    {
      "tipo": "letra",
      "texto": "No me voy a derrumbar"
