    {
      "tipo": "letra",
      "texto": ""
    },
    {
      "tipo": "tag",
      "texto": "[Verso2]    "
    },
    {
      "tipo": "acorde",
      "texto": "          Dm"
    },
    {
      "tipo": "letra",
      "texto": "Aunque el valle sea oscuro"
    },
    {
      "tipo": "acorde",
      "texto": "           Gm"
    },
    {
      "tipo": "letra",
      "texto": "No caminaré en temor   --caja suave"
    },
    {
      "tipo": "acorde",
      "texto": "     C"
    },
    {
      "tipo": "letra",
      "texto": "Tu presencia me rodea "
