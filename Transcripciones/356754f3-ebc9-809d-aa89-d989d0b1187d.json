    {
      "tipo": "acorde",
      "texto": "       Bb"
    },
    {
      "tipo": "letra",
      "texto": "Porque sé que estás conmigo"
    },
    {
      "tipo": "acorde",
      "texto": "      A              A7"
    },
    {
      "tipo": "letra",
      "texto": "Y no me vas a soltar"
