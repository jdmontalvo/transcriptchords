    },
    {
      "tipo": "letra",
      "texto": "Jesús, has mi carácter"
    },
    {
      "tipo": "acorde",
      "texto": "            C"
    },
    {
      "tipo": "letra",
      "texto": "Más como el tuyo"
    },
    {
